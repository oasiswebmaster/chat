-white/50 focus:bg-white/80 focus:ring-2 focus:ring-blue-400 rounded-xl text-base font-medium text-gray-800 transition-all shadow-inner outline-none placeholder-gray-500 placeholder-opacity-70\"\n            />\n          </div>\n        </div>\n\n        {/* Content Area Wrap */}\n        <div className=\"flex-1 flex overflow-hidden bg-transparent w-full\">\n          \n          {/* Left Sidebar */}\n          <div className=\"w-72 bg-white/30 border-r border-white/30 overflow-y-auto py-6 shrink-0 hidden md:block relative z-0\">\n            <h3 className=\"text-sm font-bold text-gray-500 uppercase tracking-widest mb-4 px-6 drop-shadow-sm\">System Locations</h3>\n            <div className=\"px-3\">\n              <SidebarTree \n                node={rootFolder} \n                pathSoFar={[]} \n                currentPath={pathIDs} \n                onNavigate={setPathIDs} \n              />\n            </div>\n          </div>\n\n          {/* Main Grid View */}\n          <div className=\"flex-1 overflow-y-auto px-4 py-6 sm:p-8 bg-white/50\" onClick={() => setHighlightedFileId(null)}>\n            <div className=\"mb-8 md:hidden px-2\">\n               <h1 className=\"text-3xl font-bold text-gray-900 drop-shadow-sm\">{currentFolder.name.replace(/-/g, \' \')}</h1>\n            </div>\n            \n            <div className=\"grid grid-cols-2 sm:grid-cols-3 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 sm:gap-6 justify-items-center\">\n              {currentFolder.children?.map(file => {\n                const isHighlighted = highlightedFileId === file.id;\n                \n                return (\n                  <div\n                    key={file.id}\n                    onClick={(e) => {\n                      e.stopPropagation();\n                      setHighlightedFileId(file.id);\n                    }}\n                    onDoubleClick={(e) => {\n                      e.stopPropagation();\n                      handleFileAction(file);\n                    }}\n                    className={`flex flex-col items-center p-4 sm:p-6 w-full max-w-[180px] rounded-[1.5rem] cursor-pointer transition-all ${\n                      isHighlighted \n                        ? \'bg-white/80 ring-2 ring-blue-500/50 shadow-md\' \n                        : \'hover:bg-white/60 border border-transparent hover:border-white/50 hover:shadow-sm\'\n                    }`}\n                  >\n                    {getIconForType(file.type, file.name)}\n                    <span \n                      className={`text-sm sm:text-base text-center leading-snug break-words w-full px-1 ${\n                        isHighlighted ? \'text-blue-900 font-bold\' : \'text-gray-800 font-semibold\'\n                      }`}\n                      style={{\n                        display: \'-webkit-box\',\n                        WebkitLineClamp: 3,\n                        WebkitBoxOrient: \'vertical\',\n                        overflow: \'hidden\'\n                      }}\n                    >\n                      {file.name.replace(/-/g, \' \')}\n                    </span>\n                    {file.size && (\n                      <span className=\"text-xs sm:text-sm text-gray-500 font-medium mt-2\">{file.size}</span>\n                    )}\n                  </div>\n                );\n              })}\n            </div>\n\n            {/* Empty State */}\n            {(!currentFolder.children || currentFolder.children.length === 0) && (\n              <div className=\"flex flex-col items-center justify-center h-full text-gray-500 py-24 sm:py-32 opacity-80\">\n                <Folder size={80} className=\"text-gray-300 mb-6 drop-shadow-sm\" strokeWidth={1} fill=\"rgba(255,255,255,0.5)\" />\n                <p className=\"text-2xl font-bold text-gray-600 drop-shadow-sm\">Folder is Empty</p>\n                <p className=\"text-lg mt-2 font-medium\">No documents have been uploaded here yet.</p>\n              </div>\n            )}\n          </div>\n        </div>\n\n        {/* Status Bar */}\n        <div className=\"h-12 bg-white/40 border-t border-white/30 flex items-center justify-center text-sm text-gray-600 font-medium shrink-0 select-none px-4 drop-shadow-sm\">"
      }
      num_matches: 1
    }
  }
}
