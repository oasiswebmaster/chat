hite/50 focus:bg-white/80 focus:ring-2 focus:ring-blue-400 rounded-xl text-base font-medium text-gray-800 transition-all shadow-inner outline-none placeholder-gray-500 placeholder-opacity-70\"\n            />\n          </div>\n        </div>\n\n        {/* Content Area Wrap */}\n        <div className=\"flex-1 flex overflow-hidden bg-transparent w-full\">\n          \n          {/* Left Sidebar */}\n          <div className=\"w-72 bg-white/30 border-r border-white/30 overflow-y-auto py-6 shrink-0 hidden md:block relative z-0\">\n            <h3 className=\"text-sm font-bold text-gray-500 uppercase tracking-widest mb-4 px-6 drop-shadow-sm\">System Locations</h3>\n            <div className=\"px-3\">\n              <SidebarTree \n                node={rootFolder} \n                pathSoFar={[]} \n                currentPath={pathIDs} \n                onNavigate={setPathIDs} \n              />\n            </div>\n          </div>\n\n          {/* Main Grid View */}\n          <div className=\"flex-1 overflow-y-auto px-4 py-6 sm:p-8 bg-white/50\" onClick={() => setHighlightedFileId(null)}>\n            <div className=\"mb-8 md:hidden px-2\">\n               <h1 className=\"text-3xl font-bold text-gray-900 drop-shadow-sm\">{currentFolder.name.replace(/-/g, \' \')}</h1>\n            </div>\n            \n            <div className=\"grid grid-cols-2 sm:grid-cols-3 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 sm:gap-6 justify-items-center\">\n              {currentFolder.children?.map(file => {\n                const isHighlighted = highlightedFileId === file.id;\n                \n                return (\n                  <div\n                    key={file.id}\n                    onClick={(e) => {\n                      e.stopPropagation();\n                      setHighlightedFileId(file.id);\n                    }}\n                    onDoubleClick={(e) => {\n                      e.stopPropagation();\n                      handleFileAction(file);\n      