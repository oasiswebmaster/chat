`}\n                    >\n                      {file.name}\n                    </span>\n                  </div>\n                );\n              })}\n            </div>\n\n            {(!currentFolder.children || currentFolder.children.length === 0) && (\n              <div className=\"absolute inset-0 flex items-center justify-center text-[#ffb000] opacity-40 font-mono text-xs uppercase\">\n                > EMPTY_DIRECTORY\n              </div>\n            )}\n          </div>\n        </div>\n\n        {/* Status Bar */}\n        <div className=\"h-10 bg-[#ffb000] text-black flex items-center justify-between px-6 shrink-0 relative z-10 font-bold uppercase text-[10px] border-t border-[#333]\">\n          <div className=\"flex items-center gap-4 text-black\">\n            <span>{currentFolder.children?.length || 0} OBJECT(S)</span>\n            {highlightedFileId && (\n              <span className=\"opacity-80\">\n                SELECTED: {currentFolder.children?.find(c => c.id === highlightedFileId)?.name}\n              </span>\n            )}\n          </div>\n          <span className=\"bg-black text-[#ffb000] px-3 py-1 text-[9px] tracking-wider\">NETWORK: ONLINE</span>\n        </div>\n      </DesktopWindow>"
