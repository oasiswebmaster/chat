ow-auto\">\n                  <img src={file.content} alt={file.name} className=\"max-w-full h-auto object-contain shadow-md border-2 border-white shadow-[2px_2px_0px_rgba(0,0,0,0.5)]\" />\n                </div>\n              )}\n              \n              {file.type === \'audio\' && (\n                <div className=\"flex flex-col items-center gap-6 text-black bg-gray-300 w-full h-full justify-center p-8\">\n                  <div className=\"w-24 h-24 bg-[#000080] text-white flex items-center justify-center border-4 border-white shadow-[4px_4px_0_rgba(0,0,0,1)] hover:scale-105 transition-transform duration-200 origin-center cursor-pointer\">\n                    <Music size={40} className=\"animate-pulse\" />\n                  </div>\n                  <div className=\"flex flex-col items-center\">\n                    <span className=\"font-sans text-xs font-bold uppercase tracking-wider mb-2\">Now Playing</span>\n                    <span className=\"font-mono bg-white px-4 py-2 border-2 border-black shadow-[2px_2px_0_rgba(0,0,0,0.5)]\">\n                      {file.name}\n                    </span>\n                  </div>\n                </div>\n              )}\n            </div>\n\n            {/* Bottom Actions */}\n            <div className=\"flex justify-end pt-3 pb-1\">\n              <button \n                onClick={onClose} \n                className=\"px-6 py-1 retro-outset retro-active font-mono text-sm font-bold text-black\"\n              >\n                Close\n              </button>\n            </div>\n          </div>\n        </DesktopWindow>\n      </motion.div>\n    </div>\n  );\n}\n"
    }
