  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useMemo, useEffect } from \'react\';\nimport { DesktopWindow } from \'./components/DesktopWindow\';\nimport { FileViewerModal } from \'./components/FileViewerModal\';\nimport { SidebarTree } from \'./components/SidebarTree\';\nimport { rootFolder } from \'./data\';\nimport { FileSystemNode, FileType } from \'./types\';\nimport { ArrowUpLeft, HardDrive, FileText, Image as ImageIcon, Music, Folder, File as FileIconGeneric } from \'lucide-react\';\n\nexport default function App() {\n  const [pathIDs, setPathIDs] = useState<string[]>([\'root\']);\n  const [selectedFile, setSelectedFile] = useState<FileSystemNode | null>(null);\n  const [highlightedFileId, setHighlightedFileId] = useState<string | null>(null);\n\n  // Reset highlight when path changes\n  useEffect(() => {\n    setHighlightedFileId(null);\n  }, [pathIDs]);\n\n  // Resolve current folder object\n  const currentFolder = useMemo(() => {\n    let current = rootFolder;\n    for (let i = 1; i < pathIDs.length; i++) {\n      const next = current.children?.find(c => c.id === pathIDs[i]);\n      if (next) current = next;\n    }\n    return current;\n  }, [pathIDs]);\n\n  // Resolve absolute path string\n  const absolutePathSegments = useMemo(() => {\n    let current = rootFolder;\n    let p = [rootFolder.name];\n    for (let i = 1; i < pathIDs.length; i++) {\n      const next = current.children?.find(c => c.id === pathIDs[i]);\n      if (next) {\n        current = next;\n        p.push(next.name);\n      }\n    }\n    return p;\n  }, [pathIDs]);\n\n  const handleNavigateUp = () => {\n    if (pathIDs.length > 1) {\n      setPathIDs(prev => prev.slice(0, -1));\n    }\n  };\n\n  const handleFileAction = (file: FileSystemNode) => {\n    if (file.type === \'folder\') {\n      setPathIDs(prev => [...prev, file.id]);\n    } else {\n      setSelectedFile(file);\n    }\n  };\n\n  const getIconForType = (type: FileType, isHighlighted: boolean) => {\n    const className = `w-10 h-10 ${isHighlighted ? \'text-white\' : \'text-gray-800\'}`;\n    const fill = isHighlighted ? \'white\' : \'transparent\';\n    \n    switch (type) {\n      case \'folder\': return <Folder className={className} fill={isHighlighted ? \'white\' : \'#facc15\'} stroke={isHighlighted ? \'white\' : \'black\'} />;\n      case \'document\': return <FileText className={className} />;\n      case \'image\': return <ImageIcon className={className} />;\n      case \'audio\': return <Music className={className} />;\n      default: return <FileIconGeneric className={className} />;\n    }\n  };\n\n  return (\n    <div className=\"min-h-screen bg-teal-800 flex items-center justify-center p-2 sm:p-8 selection:bg-blue-800 selection:text-white font-sans text-sm pb-12 w-full\">\n      <DesktopWindow \n        title=\"FileNet Portal [Secure]\" \n        className=\"w-full max-w-5xl h-[90vh] shadow-[12px_12px_0px_rgba(0,0,0,0.5)] border-2 border-black\"\n      >\n        {/* Menu Bar Layout */}\n        <div className=\"bg-gray-200 border-b-2 border-white px-2 py-0.5 flex gap-4 text-xs font-sans\">\n          <span className=\"cursor-pointer hover:bg-black hover:text-white px-2 py-0.5\"><u>F</u>ile</span>\n          <span className=\"cursor-pointer hover:bg-black hover:text-white px-2 py-0.5\"><u>E</u>dit</span>\n          <span className=\"cursor-pointer hover:bg-black hover:text-white px-2 py-0.5\"><u>V</u>iew</span>\n          <span className=\"cursor-pointer hover:bg-black hover:text-white px-2 py-0.5\"><u>H</u>elp</span>\n        </div>\n\n        {/* Toolbar */}\n        <div className=\"bg-gray-200 border-b-2 border-gray-400 px-3 py-2 flex items-center gap-3\">\n          <button\n            onClick={handleNavigateUp}\n            disabled={pathIDs.length === 1}\n            className=\"px-3 py-1 retro-outset retro-active flex items-center gap-1 disabled:opacity-50 disabled:active:border-t-white disabled:active:border-l-white disabled:active:border-b-gray-600 disabled:active:border-r-gray-600\"\n          >\n            <ArrowUpLeft size={16} /> <span className=\"font-sans text-sm\">Up</span>\n          </button>\n          \n          {/* Address Bar */}\n          <div className=\"flex-1 retro-inset px-2 py-1 flex items-center gap-2\">\n            <HardDrive size={16} className=\"text-gray-500 shrink-0\" />\n            <span className=\"font-mono text-sm truncate pt-0.5 text-black\">\n              C:\\HOSTING\\{absolutePathSegments.join(\'\\\\\')}\n            </span>\n          </div>\n        </div>\n\n        {/* Content Split Area */}\n        <div className=\"flex-1 flex overflow-hidden bg-gray-200 p-1 pl-2 gap-1 pb-2\">\n          \n          {/* Sidebar Area */}\n          <div className=\"w-1/3 max-w-[240px] bg-white overflow-y-auto retro-inset p-2\">\n            <SidebarTree \n              node={rootFolder} \n              pathSoFar={[]} \n              currentPath={pathIDs} \n              onNavigate={setPathIDs} \n            />\n          </div>\n\n          {/* Main Display Area */}\n          <div className=\"flex-1 bg-white overflow-y-auto retro-inset relative\">\n            <div className=\"p-4 grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6 items-start justify-items-center\">\n              {currentFolder.children?.map(file => {\n                const isHighlighted = highlightedFileId === file.id;\n                \n                return (\n                  <div\n                    key={file.id}\n                    onClick={(e) => {\n                      e.stopPropagation();\n                      setHighlightedFileId(file.id);\n                    }}\n                    onDoubleClick={(e) => {\n                      e.stopPropagation();\n                      handleFileAction(file);\n                    }}\n                    className={`flex flex-col items-center gap-2 p-3 w-28 cursor-pointer select-none group border-2 ${\n                      isHighlighted \n                        ? \'bg-[#000080] border-[#000080] border-dotted text-white shadow-sm\' \n                        : \'border-transparent hover:border-gray-300 hover:border-dotted\'\n                    }`}\n                  >\n                    {getIconForType(file.type, isHighlighted)}\n                    <span \n                      className={`font-mono text-xs text-center leading-tight break-words px-1 line-clamp-3 ${\n                        isHighlighted ? \'bg-[#000080] text-white\' : \'text-black bg-white group-hover:bg-blue-100\'\n                      }`}\n                    >\n                      {file.name}\n                    </span>\n                  </div>\n                );\n              })}\n            </div>\n\n            {(!currentFolder.children || currentFolder.children.length === 0) && (\n              <div className=\"absolute inset-0 flex items-center justify-center text-gray-400 font-mono text-sm\">\n                ( Folder is empty )\n              </div>\n            )}\n          </div>\n        </div>\n\n        {/* Status Bar */}\n        <div className=\"bg-gray-200 border-t-2 border-white px-3 py-1 flex justify-between font-sans text-xs text-black border-b-2 border-gray-400 shadow-[inset_0_-1px_0_rgba(255,255,255,1)]\">\n          <div className=\"flex items-center gap-4\">\n            <span className=\"retro-inset px-2 py-0.5 bg-gray-100\">{currentFolder.children?.length || 0} object(s)</span>\n            {highlightedFileId && (\n              <span className=\"text-gray-600\">\n                Selected: {currentFolder.children?.find(c => c.id === highlightedFileId)?.name}\n              </span>\n            )}\n          </div>\n          <span className=\"retro-inset px-2 py-0.5 bg-gray-100 border-l-2 border-gray-400 pl-4\">Network: Online</span>\n        </div>\n      </DesktopWindow>\n\n      {/* Overlays */}\n      {selectedFile && (\n        <FileViewerModal \n          file={selectedFile} \n          onClose={() => setSelectedFile(null)} \n        />\n      )}\n    </div>\n  );\n}\n"
    }
    diff {
      end_line: 8
      unified_diff {
        lines {
