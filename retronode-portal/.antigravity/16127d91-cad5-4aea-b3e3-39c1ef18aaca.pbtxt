      original_chunk {
        target_content: "        {/* Modern App Toolbar */}\n        <div className=\"h-20 bg-white border-b border-gray-200 px-4 sm:px-6 flex items-center justify-between shrink-0 relative z-10 w-full\">\n          <div className=\"flex items-center gap-4 sm:gap-6 w-full max-w-4xl\">\n            <button\n              onClick={handleNavigateUp}\n              disabled={pathIDs.length === 1}\n              className=\"px-4 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-800 rounded-xl flex items-center gap-2 disabled:opacity-40 disabled:hover:bg-gray-100 transition-colors font-bold text-base shadow-sm ring-1 ring-black/5\"\n            >\n              <ChevronLeft size={20} strokeWidth={2.5} /> <span className=\"hidden sm:inline\">Back</span>\n            </button>\n            \n            {/* Breadcrumbs for easier navigation */}\n            <div className=\"flex-1 flex flex-wrap items-center gap-2 text-base sm:text-lg text-gray-500 font-medium overflow-hidden\">\n              {absolutePathSegments.map((segment, index) => (\n                <React.Fragment key={index}>\n                  {index > 0 && <ChevronRight size={20} className=\"text-gray-300 shrink-0\" />}\n                  <span className={`truncate ${index === absolutePathSegments.length - 1 ? \'text-gray-900 font-bold\' : \'\'}`}>\n                    {segment.replace(/-/g, \' \')}\n                  </span>\n                </React.Fragment>\n              ))}\n            </div>\n          </div>\n          \n          {/* Search Placeholder */}\n          <div className=\"relative w-64 lg:w-80 hidden md:block\">\n            <div className=\"absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none\">\n              <Search size={18} className=\"text-gray-400\" strokeWidth={2.5} />\n            </div>\n            <input \n              type=\"text\" \n              placeholder=\"Search files...\"\n              className=\"w-full pl-12 pr-4 py-3 border-none bg-gray-100 focus:bg-white focus:ring-2 focus:ring-blue-500 rounded-xl text-base font-medium text-gray-800 transition-all shadow-inner outline-none placeholder-gray-400\"\n            />\n          </div>\n        </div>\n\n        {/* Content Area Wrap */}\n        <div className=\"flex-1 flex overflow-hidden bg-white w-full\">\n          \n          {/* Left Sidebar */}\n          <div className=\"w-72 bg-gray-50 border-r border-gray-200 overflow-y-auto py-6 shrink-0 hidden md:block relative z-0\">\n            <h3 className=\"text-sm font-bold text-gray-400 uppercase tracking-widest mb-4 px-6\">System Locations</h3>\n            <div className=\"px-3\">\n              <SidebarTree \n                node={rootFolder} \n                pathSoFar={[]} \n                currentPath={pathIDs} \n                onNavigate={setPathIDs} \n              />\n            </div>\n          </div>\n\n          {/* Main Grid View */}\n          <div className=\"flex-1 overflow-y-auto px-4 py-6 sm:p-8 bg-white\" onClick={() => setHighlightedFileId(null)}>\n            <div className=\"mb-8 md:hidden px-2\">\n               <h1 className=\"text-3xl font-bold text-gray-900\">{currentFolder.name.replace(/-/g, \' \')}</h1>\n            </div>\n            \n            <div className=\"grid grid-cols-2 sm:grid-cols-3 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 sm:gap-6 justify-items-center\">\n              {currentFolder.children?.map(file => {\n                const isHighlighted = highlightedFileId === file.id;\n                \n                return (\n                  <div\n                    key={file.id}\n                    onClick={(e) => {\n                      e.stopPropagation();\n                      setHighlightedFileId(file.id);\n                    }}\n                    onDoubleClick={(e) => {\n                      e.stopPropagation();\n                      handleFileAction(file);\n                    }}\n                    className={`flex flex-col items-center p-4 sm:p-6 w-full max-w-[180px] rounded-[1.5rem] cursor-pointer transition-all ${\n                      isHighlighted \n                        ? \'bg-blue-50 ring-2 ring-blue-500/50 shadow-sm\' \n                        : \'hover:bg-gray-50 border border-transparent hover:border-gray-100\'\n                    }`}\n                  >\n                    {getIconForType(file.type, file.name)}\n                    <span \n                      className={`text-sm sm:text-base text-center leading-snug break-words w-full px-1 ${\n                        isHighlighted ? \'text-blue-900 font-bold\' : \'text-gray-800 font-medium\'\n                      }`}\n                      style={{\n                        display: \'-webkit-box\',\n                        WebkitLineClamp: 3,\n                        WebkitBoxOrient: \'vertical\',\n                        overflow: \'hidden\'\n                      }}\n                    >\n                      {file.name.replace(/-/g, \' \')}\n                    </span>\n                    {file.size && (\n                      <span className=\"text-xs sm:text-sm text-gray-400 font-medium mt-2\">{file.size}</span>\n                    )}\n                  </div>\n                );\n              })}\n            </div>\n\n            {/* Empty State */}\n            {(!currentFolder.children || currentFolder.children.length === 0) && (\n              <div className=\"flex flex-col items-center justify-center h-full text-gray-400 py-24 sm:py-32\">\n                <Folder size={80} className=\"text-gray-200 mb-6\" strokeWidth={1} fill=\"#f3f4f6\" />\n                <p className=\"text-2xl font-bold text-gray-500\">Folder is Empty</p>\n                <p className=\"text-lg mt-2 font-medium\">No documents have been uploaded here yet.</p>\n              </div>\n            )}\n          </div>\n        </div>\n\n        {/* Status Bar */}\n        <div className=\"h-12 bg-white border-t border-gray-200 flex items-center justify-center text-sm text-gray-500 font-medium shrink-0 select-none px-4\">"
